# Reddit API (required for Reddit fetch and Collect Now)
# 1. Go to https://www.reddit.com/prefs/apps
# 2. Create app (script type)
# 3. Copy client id (under app name) and secret
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=TrendSentimentApp/1.0

# Optional: Twitter API v2 (Bearer token)
# Get from https://developer.twitter.com/en/portal/dashboard
# TWITTER_BEARER_TOKEN=your_bearer_token

# Optional: Real-time collection interval (minutes)
# COLLECT_INTERVAL_MIN=5
# REDDIT_SUBREDDITS=python,technology,worldnews
